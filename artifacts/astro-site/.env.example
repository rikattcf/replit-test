# Storyblok
# Your preview token (for draft content in development)
STORYBLOK_TOKEN=your_preview_token_here

# Your public token (for published content in production)
STORYBLOK_PUBLIC_TOKEN=your_public_token_here

# Your Storyblok Space ID (found in Storyblok > Settings > General)
STORYBLOK_SPACE_ID=your_space_id_here

# Web Awesome Pro kit code (from fontawesome.com > Kits)
VITE_WA_KIT_CODE=your_kit_code_here

# Set to 'true' in production
IS_PRODUCTION=false
