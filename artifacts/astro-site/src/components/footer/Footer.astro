---
/**
 * Footer — 3 columns of nav links, legal strip, social icons.
 * Swap `footerColumns` for Storyblok-driven data when ready.
 */

interface FooterLink {
  label: string;
  href: string;
}

interface FooterColumn {
  heading: string;
  links: FooterLink[];
}

const footerColumns: FooterColumn[] = [
  {
    heading: 'Products',
    links: [
      { label: 'Dexcom G7',              href: '/products/g7' },
      { label: 'Dexcom G6',              href: '/products/g6' },
      { label: 'Apps & Connectivity',    href: '/products/apps' },
    ],
  },
  {
    heading: 'Support',
    links: [
      { label: 'Getting Started',        href: '/support/getting-started' },
      { label: 'Insurance & Access',     href: '/support/insurance' },
      { label: 'Help Centre',            href: '/support/help' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About Dexcom',           href: '/about' },
      { label: 'Newsroom',               href: '/news' },
      { label: 'Careers',                href: '/careers' },
    ],
  },
];

const legalLinks = [
  { label: 'Privacy Policy',             href: '/privacy' },
  { label: 'Cookie Policy',              href: '/cookies' },
  { label: 'Terms of Use',              href: '/terms' },
  { label: 'Accessibility',             href: '/accessibility' },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" aria-label="Site footer">
  <div class="container">

    <!-- Top: logo + columns -->
    <div class="site-footer__top">
      <!-- Logo -->
      <div class="site-footer__brand">
        <a href="/" aria-label="Dexcom home" class="site-footer__logo">
          <svg width="120" height="32" viewBox="0 0 120 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <text x="0" y="26" font-family="'Helvetica Neue',Helvetica,Arial,sans-serif"
                  font-size="28" font-weight="700" fill="#00AA55">dexcom</text>
          </svg>
        </a>
        <p class="site-footer__tagline">Better diabetes management, every day.</p>

        <!-- Social links -->
        <div class="site-footer__social" aria-label="Social media">
          <a href="https://twitter.com/dexcom" aria-label="Dexcom on X (Twitter)" class="social-link" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://facebook.com/dexcom" aria-label="Dexcom on Facebook" class="social-link" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://instagram.com/dexcom" aria-label="Dexcom on Instagram" class="social-link" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://youtube.com/dexcom" aria-label="Dexcom on YouTube" class="social-link" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav columns -->
      <nav class="site-footer__nav" aria-label="Footer navigation">
        {footerColumns.map(col => (
          <div class="site-footer__col">
            <h3 class="site-footer__col-heading">{col.heading}</h3>
            <ul role="list">
              {col.links.map(link => (
                <li>
                  <a href={link.href} class="site-footer__link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </div>

    <!-- Divider -->
    <hr class="site-footer__divider" />

    <!-- Bottom: legal -->
    <div class="site-footer__bottom">
      <p class="site-footer__copy">
        &copy; {currentYear} Dexcom, Inc. All rights reserved. For UK use only.
      </p>
      <ul class="site-footer__legal" role="list">
        {legalLinks.map(l => (
          <li><a href={l.href} class="site-footer__legal-link">{l.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background-color: var(--color-gray-900);
  color: var(--color-gray-300);
  padding-top: var(--space-16);
  padding-bottom: var(--space-8);
  margin-top: auto;
}

.site-footer__top {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: var(--space-12);
  align-items: start;
}

.site-footer__brand { display: flex; flex-direction: column; gap: var(--space-5); }

.site-footer__tagline {
  font-size: var(--font-size-sm);
  color: var(--color-gray-400);
  line-height: var(--line-height-snug);
  max-width: 200px;
}

.site-footer__social {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
}

.social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: var(--radius-full);
  background: var(--color-gray-800);
  color: var(--color-gray-300);
  transition: background var(--transition-fast), color var(--transition-fast);
}
.social-link:hover {
  background: var(--color-brand-green);
  color: white;
}

/* Footer nav */
.site-footer__nav {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-8);
}

.site-footer__col-heading {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-brand-white);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: var(--space-5);
}

.site-footer__col ul {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.site-footer__link {
  font-size: var(--font-size-sm);
  color: var(--color-gray-400);
  transition: color var(--transition-fast);
}
.site-footer__link:hover { color: var(--color-brand-green); }

/* Divider */
.site-footer__divider {
  border: none;
  border-top: 1px solid var(--color-gray-800);
  margin-block: var(--space-8);
}

/* Bottom strip */
.site-footer__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-4);
}

.site-footer__copy {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
}

.site-footer__legal {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
}

.site-footer__legal-link {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
  transition: color var(--transition-fast);
}
.site-footer__legal-link:hover { color: var(--color-brand-green); }

/* Responsive */
@media (max-width: 900px) {
  .site-footer__top {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  .site-footer__nav {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 640px) {
  .site-footer__nav {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }
  .site-footer__bottom {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 400px) {
  .site-footer__nav { grid-template-columns: 1fr; }
}
</style>
